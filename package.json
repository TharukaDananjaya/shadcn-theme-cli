	"bin": {
		"shadcn-theme": "./dist/index.js"
	},
	"scripts": {
		"dev": "tsx src/index.ts",
		"build": "tsc",
		"prepare": "npm run build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/TharukaDananjaya/shadcn-theme-cli.git"
	},
	"keywords": [
